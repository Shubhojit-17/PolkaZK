# PolkaZK Environment Configuration
# Copy to .env and fill in your values

# Private key (with 0x prefix) for deploying contracts
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# RPC endpoint for Westend Asset Hub
# Testnet Eth-RPC endpoint:
RPC_URL=https://westend-asset-hub-eth-rpc.polkadot.io

# For local testing with eth-rpc-adapter / kitchensink node:
# RPC_URL=http://127.0.0.1:8545

# Deployed contract addresses (filled after deployment)
RUST_VERIFIER_ADDRESS=
VOTING_CONTRACT_ADDRESS=
